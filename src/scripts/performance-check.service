[Unit]
Description=Video Embedding Service Performance Check
After=network.target

[Service]
Type=oneshot
User=ec2-user
Environment="PATH=/home/ec2-user/miniconda/bin:/opt/pytorch/bin:/usr/local/bin:/usr/bin:/bin"
Environment="PYTHONPATH=/home/ec2-user/miniconda/lib/python3.9/site-packages"
ExecStart=/home/ec2-user/shortvideo-online/src/scripts/run_performance_check.sh
WorkingDirectory=/home/ec2-user/shortvideo-online/src/scripts/

[Install]
WantedBy=multi-user.target